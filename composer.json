{
    "name": "finity-labs/fin-sentinel",
    "description": "Exception monitoring and debug email channel for Filament.",
    "keywords": ["laravel", "filament", "error-monitoring", "exceptions", "debug"],
    "license": "MIT",
    "authors": [
        {
            "name": "Finity Labs",
            "email": "filament.infinity@gmail.com",
            "role": "Developer"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "filament/spatie-laravel-settings-plugin": "^3.0|^4.0|^5.0",
        "illuminate/contracts": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-settings": "^3.0|^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "FinityLabs\\FinSentinel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FinityLabs\\FinSentinel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FinityLabs\\FinSentinel\\FinSentinelServiceProvider"
            ],
            "aliases": {
                "FinSentinel": "FinityLabs\\FinSentinel\\Facades\\FinSentinel"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
